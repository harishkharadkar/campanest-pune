rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isStudent() {
      return isSignedIn() && userRole() == "student";
    }

    function isViewIncrementOnly() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let removed = request.resource.data.diff(resource.data).removedKeys();
      let oldViews = resource.data.views is number
        ? resource.data.views
        : (resource.data.totalViews is number ? resource.data.totalViews : 0);

      return removed.size() == 0
        && changed.hasOnly(["views", "totalViews"])
        && request.resource.data.views is number
        && request.resource.data.totalViews is number
        && request.resource.data.views >= 0
        && request.resource.data.totalViews >= 0
        && request.resource.data.views == request.resource.data.totalViews
        && request.resource.data.views == oldViews + 1;
    }

    function isStudentRatingAggregateOnlyUpdate() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      let removed = request.resource.data.diff(resource.data).removedKeys();

      return isStudent()
        && removed.size() == 0
        && changed.hasAll(["avgRating", "averageRating", "totalRatings"])
        && changed.hasOnly(["avgRating", "averageRating", "totalRatings", "lastUpdated"])
        && request.resource.data.totalRatings is number
        && request.resource.data.totalRatings >= 0
        && request.resource.data.avgRating is number
        && request.resource.data.avgRating >= 0
        && request.resource.data.avgRating <= 5
        && request.resource.data.averageRating == request.resource.data.avgRating;
    }

    function isValidRatingWrite(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
    }

    // Users collection
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Listings collection
    match /listings/{listingId} {
      // Anyone can read listings
      allow read: if true;

      // Only admin can create/edit/delete listings.
      // Guest view counters and student rating aggregate updates are allowed as scoped exceptions.
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isViewIncrementOnly() || isStudentRatingAggregateOnlyUpdate();

      // Ratings subcollection
      match /ratings/{uid} {
        // Any logged-in user can read ratings; admin can also read.
        allow read: if request.auth != null;

        // Student can only write their OWN rating document.
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && isStudent()
          && isValidRatingWrite(uid);

        // Admin can read and write any rating.
        allow read, write: if isAdmin();
      }
    }

    // Providers collection
    match /providers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
    }

    // Admin-managed menu items.
    match /menuItems/{menuItemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read: if true;
    }
  }
}
