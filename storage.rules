rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for listing images
    match /listings/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
